*******************************  Equations  ********************************

********** Mapped Logic **********


$OpTx$FX_DC$6 <= ((NOT nRFSH AND SEL_128CHARS)
	OR (NOT nRFSH AND NOT A15 AND NOT A14 AND NOT A13));


$OpTx$INV$1 <= ((sync_counter(0))
	OR (sync_counter(1) AND sync_counter(2) AND 
	sync_counter(3) AND NOT sync_counter(4) AND NOT sync_counter(5) AND 
	sync_counter(6) AND sync_counter(7)));


A0x_I <= ((rowcnt(0) AND $OpTx$FX_DC$6)
	OR (A0 AND NOT $OpTx$FX_DC$6));
A0x <= A0x_I when A0x_OE = '1' else 'Z';
A0x_OE <= nRESET;


A10x_I <= A10;
A10x <= A10x_I when A10x_OE = '1' else 'Z';
A10x_OE <= nRESET;


A11x_I <= A11;
A11x <= A11x_I when A11x_OE = '1' else 'Z';
A11x_OE <= nRESET;


