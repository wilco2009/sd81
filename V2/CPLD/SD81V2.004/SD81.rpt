	OR (NOT A15 AND A14 AND NOT A13 AND block_2_0));
A13x <= A13x_I when A13x_OE = '1' else 'Z';
A13x_OE <= nRESET;


A14x_I <= ((A15 AND A14 AND NOT A13 AND block_6_1)
	OR (A15 AND NOT A14 AND A13 AND block_5_1)
